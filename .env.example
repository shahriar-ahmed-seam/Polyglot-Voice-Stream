# Copy to .env and fill in. The .env file is git-ignored.

# Groq handles both STT and translation (free tier: https://console.groq.com)
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxx

# ElevenLabs for voice-cloning TTS (free tier: https://elevenlabs.io)
# Leave blank to use the local CPU TTS stub instead.
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=        # id of your cloned voice (clone once in the dashboard or via clone_voice())

# Pipeline settings
SOURCE_LANG=en
TARGET_LANG=es
TTS_BACKEND=elevenlabs     # "elevenlabs" or "xtts"
