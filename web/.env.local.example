# URL of the Python WebSocket backend.
# Local dev:   ws://localhost:8000/ws
# Production:  wss://your-backend.onrender.com/ws   (must be wss:// from an https Vercel page)
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws

# Language labels shown in the UI (display only; the backend controls actual languages).
NEXT_PUBLIC_SOURCE_LANG=EN
NEXT_PUBLIC_TARGET_LANG=ES
